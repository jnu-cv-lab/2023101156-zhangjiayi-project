#  任务6：错误分类样本分析
print("\n========== 任务6：错误分类样本分析 ==========")
best_model.eval()
all_preds, all_labels = [], []
with torch.no_grad():
    for images, labels in test_loader:
        images = images.to(device)
        outputs = best_model(images)
        _, preds = torch.max(outputs, 1)
        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(labels.numpy())

errors = [(i, true, pred) for i, (true, pred) in enumerate(zip(all_labels, all_preds)) if true != pred]
print(f"测试集总样本数: {len(all_labels)}，错误样本数: {len(errors)}，准确率: {1 - len(errors)/len(all_labels):.4f}")

# 显示至少8张错误图片
num_show = min(8, len(errors))
fig, axes = plt.subplots(1, num_show, figsize=(15, 3))
if num_show == 0:
    print("没有错误样本，无法显示。")
else:
    for i in range(num_show):
        idx, true, pred = errors[i]
        img = test_set[idx][0].squeeze().numpy()
        axes[i].imshow(img, cmap='gray')
        axes[i].set_title(f"True:{true}\nPred:{pred}")
        axes[i].axis('off')
    plt.suptitle("错误分类样本示例")
    plt.tight_layout()
    plt.savefig("error_samples.png")
    plt.show()

# 统计混淆最多的类别对
from collections import Counter
confuse_pairs = Counter((true, pred) for _, true, pred in errors)
print("\n最易混淆的数字对（真实→预测）及次数：")
for (true, pred), count in confuse_pairs.most_common(5):
    print(f"  {true} → {pred}: {count}次")

print("\n错误原因分析：手写风格相似（如8与1、9与7、5与9），低分辨率下细节丢失。")
print("改进建议：增加数据增强（旋转、平移）、加深网络、使用 Dropout 或 BatchNorm。")

